model Model
	culture: en-IN
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		fastCombine
		legacyRedirects

annotation PBI_QueryOrder = ["dim_fund","dim_date","fact_nav","fact_transactions","fact_performance","fact_aum","fact_portfolio","fact_sip_industry"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DevMode"]

ref table dim_fund
ref table dim_date
ref table fact_nav
ref table fact_transactions
ref table fact_performance
ref table fact_aum
ref table fact_portfolio
ref table fact_sip_industry

